# Cổng chạy FRPControl dashboard
PORT=3000

# Thư mục lưu dữ liệu các FRP instance (mỗi instance = 1 file JSON)
DATA_DIR=./data

# Khóa bí mật (32+ ký tự): mã hóa mật khẩu FRP + ký JWT access token.
# Nếu để trống: mật khẩu FRP lưu base64 (KHÔNG an toàn), khóa JWT tự sinh vào data/.jwt-secret.
# Tạo khóa mới: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=

# Thời hạn access token (JWT) tính bằng phút (mặc định 15). Refresh token dài hơn (cấu hình trong System → Configs).
ACCESS_TOKEN_MINUTES=15

# Timeout (ms) khi gọi Admin API của frps/frpc
FRP_API_TIMEOUT=8000
